# =============================================================================
# REQUIRED
# =============================================================================

# Groq API key — powers the Whisper transcription step (free tier covers a lot)
# Get one: https://console.groq.com/keys
GROQ_API_KEY=

# Apify token — powers Instagram scraping + profile/follower fetching
# Get one: https://console.apify.com/account/integrations
# Cost: ~$0.003 per reel scraped. ~$1-2 covers most personal use.
APIFY_TOKEN=

# =============================================================================
# OPTIONAL — sensible defaults provided, override only if needed
# =============================================================================

# Where the vault (scraped creator data + Patterns/Playbook) lives.
# Default: <repo>/content-brain
# STUDY_OUTPUT_DIR=./content-brain
# CONTENT_BRAIN_ROOT=./content-brain

# Path to the `claude` CLI binary. Default: looked up from PATH.
# Override if you installed Claude Code somewhere non-standard.
# CLAUDE_BIN=/path/to/claude

# Python binary used by the webapp to spawn scrape scripts.
# Default: <repo>/.venv/bin/python (created by the setup step).
# PYTHON_BIN=/usr/local/bin/python3

# Skip heavy creators when running `npm run dev` (comma-separated, case-insensitive).
# Useful if your machine struggles with the YouTube creator (MrBeast has 773 videos).
# SKIP_CREATORS=mrbeast
